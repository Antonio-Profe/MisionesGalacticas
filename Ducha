<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>¡Misión Ducha Nocturna! - Infografía Infantil</title>
    <!-- Tailwind CSS para el diseño rápido y responsivo -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome para los iconos de robots y baño -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Letra divertida y legible para niños -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <!-- Tone.js para efectos de sonido divertidos de robots -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tone/14.8.49/Tone.js"></script>
    <style>
        body {
            font-family: 'Fredoka', sans-serif;
            background-color: #f0fdf4;
        }
        /* Configuración para el tamaño A4 exacto en impresión */
        @media print {
            body {
                background-color: #ffffff;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            .no-print {
                display: none !important;
            }
            .a4-page {
                width: 210mm;
                height: 297mm;
                margin: 0;
                padding: 10mm;
                box-shadow: none;
                border: none;
                page-break-after: always;
            }
        }
        .a4-page {
            width: 210mm;
            height: 297mm;
            max-width: 100%;
            background: linear-gradient(135deg, #e0f2fe 0%, #f0fdf4 100%);
            position: relative;
            overflow: hidden;
        }
        .title-font {
            font-family: 'Outfit', sans-serif;
        }
        .step-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .step-card:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="flex flex-col items-center justify-center min-h-screen p-4 bg-slate-900">

    <!-- Botón de Control Excluido de la Impresión -->
    <div class="no-print mb-4 flex gap-4">
        <button onclick="window.print()" class="px-6 py-3 bg-emerald-500 text-white font-bold rounded-full shadow-lg hover:bg-emerald-600 transition-all flex items-center gap-2">
            <i class="fa-solid fa-print"></i> Imprimir en Tamaño A4
        </button>
        <button onclick="completarMision()" class="px-6 py-3 bg-blue-500 text-white font-bold rounded-full shadow-lg hover:bg-blue-600 transition-all flex items-center gap-2">
            <i class="fa-solid fa-wand-magic-sparkles"></i> ¡Modo Interactivo!
        </button>
    </div>

    <!-- PÁGINA A4 PRINCIPAL -->
    <div id="canvas-a4" class="a4-page shadow-2xl rounded-3xl border-8 border-cyan-400 p-6 flex flex-col justify-between relative bg-white">
        
        <!-- Elementos Decorativos de Fondo (Burbujas y Engranajes) -->
        <div class="absolute top-10 left-5 text-cyan-200 text-4xl opacity-50 animate-bounce"><i class="fa-solid fa-cog"></i></div>
        <div class="absolute top-40 right-8 text-emerald-200 text-3xl opacity-40"><i class="fa-solid fa-gears"></i></div>
        <div class="absolute bottom-20 left-10 text-blue-200 text-5xl opacity-40"><i class="fa-solid fa-bath"></i></div>
        <div class="absolute bottom-40 right-6 text-purple-200 text-4xl opacity-50"><i class="fa-solid fa-star"></i></div>
        
        <!-- Burbujas Flotantes -->
        <div class="absolute top-1/3 left-1/4 w-4 h-4 bg-cyan-300 rounded-full opacity-40"></div>
        <div class="absolute top-1/2 right-1/4 w-6 h-6 bg-blue-300 rounded-full opacity-30"></div>
        <div class="absolute bottom-1/3 right-12 w-3 h-3 bg-teal-300 rounded-full opacity-50"></div>

        <!-- CABECERA -->
        <div class="text-center relative z-10">
            <div class="inline-block bg-cyan-500 text-white text-xs px-4 py-1 rounded-full uppercase tracking-widest font-bold mb-2 shadow-sm">
                🤖 PROTOCOLO DE RECARGA NOCTURNA
            </div>
            <h1 class="title-font text-4xl font-extrabold text-slate-800 tracking-tight leading-none drop-shadow-sm">
                ¡MISIÓN: <span class="text-cyan-500">SUPER DUCHA</span>! 🚿
            </h1>
            <p class="text-sm text-slate-500 mt-1">Sigue los pasos de la tripulación de robots para brillar como una estrella.</p>
        </div>

        <!-- MENSAJE MOTIVADOR SUPERIOR -->
        <div class="text-center bg-amber-100 border-2 border-dashed border-amber-400 rounded-2xl py-1 px-4 mx-6 my-0.5 z-10">
            <span class="text-amber-700 text-sm md:text-base font-bold">
                🚀 ¡Cargando energía limpia al 100%! Cada noche te hace más fuerte y más sabio.<br>¡A por ello!
            </span>
        </div>

        <!-- LISTA DE PASOS (Estructura de 5 Pasos en Formato Vertical/ZizZag Optimizado) -->
        <div class="grid grid-cols-1 gap-3 my-2 z-10 px-4">
            
            <!-- PASO 1 -->
            <div id="step-1" class="step-card flex items-center bg-white border-2 border-blue-200 rounded-2xl p-3 shadow-sm hover:border-blue-400">
                <div class="flex-shrink-0 w-12 h-12 bg-blue-500 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md border-2 border-white">
                    1
                </div>
                <!-- Mini Avatar SVG de Robot Recolector -->
                <div class="w-16 h-16 mx-3 flex items-center justify-center bg-blue-100 rounded-xl border border-blue-200">
                    <svg class="w-12 h-12" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="18" y="18" width="28" height="24" rx="4" fill="#3B82F6" stroke="#1E3A8A" stroke-width="2"/>
                        <circle cx="27" cy="27" r="3" fill="white"/>
                        <circle cx="27" cy="27" r="1.5" fill="#1E3A8A"/>
                        <circle cx="37" cy="27" r="3" fill="white"/>
                        <circle cx="37" cy="27" r="1.5" fill="#1E3A8A"/>
                        <rect x="26" y="34" width="12" height="3" rx="1" fill="#FFF"/>
                        <path d="M12 28 H18 M46 28 H52" stroke="#1E3A8A" stroke-width="2" stroke-linecap="round"/>
                        <rect x="22" y="42" width="6" height="8" fill="#1D4ED8"/>
                        <rect x="36" y="42" width="6" height="8" fill="#1D4ED8"/>
                        <!-- Item: Toalla / Ropa -->
                        <path d="M14 44 H50 V48 H14 Z" fill="#93C5FD" stroke="#1E3A8A" stroke-width="1.5"/>
                    </svg>
                </div>
                <div class="flex-grow">
                    <h3 class="text-sm font-bold text-blue-700 uppercase tracking-wide">Paso de Preparación</h3>
                    <p class="text-slate-700 text-sm font-semibold leading-snug">
                        Coge tu ropa, zapatillas, toalla y manopla.
                    </p>
                </div>
                <div class="px-2 text-right text-xs text-blue-500 font-bold hidden md:block">
                    ¡Todo listo! 🎒
                </div>
            </div>

            <!-- PASO 2 -->
            <div id="step-2" class="step-card flex items-center bg-white border-2 border-teal-200 rounded-2xl p-3 shadow-sm hover:border-teal-400">
                <div class="flex-shrink-0 w-12 h-12 bg-teal-500 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md border-2 border-white">
                    2
                </div>
                <!-- Mini Avatar SVG de Robot en Baño / Desvistiéndose -->
                <div class="w-16 h-16 mx-3 flex items-center justify-center bg-teal-100 rounded-xl border border-teal-200">
                    <svg class="w-12 h-12" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="18" y="16" width="28" height="24" rx="4" fill="#0D9488" stroke="#115E59" stroke-width="2"/>
                        <circle cx="27" cy="25" r="3" fill="#FFF"/>
                        <circle cx="37" cy="25" r="3" fill="#FFF"/>
                        <path d="M28 32 C28 32 32 35 36 32" stroke="#115E59" stroke-width="2" stroke-linecap="round"/>
                        <!-- Cesto de ropa -->
                        <path d="M22 40 L24 54 H40 L42 40 Z" fill="#CCFBF1" stroke="#115E59" stroke-width="2"/>
                        <line x1="27" y1="42" x2="29" y2="52" stroke="#0D9488" stroke-width="1.5"/>
                        <line x1="32" y1="42" x2="32" y2="52" stroke="#0D9488" stroke-width="1.5"/>
                        <line x1="37" y1="42" x2="35" y2="52" stroke="#0D9488" stroke-width="1.5"/>
                    </svg>
                </div>
                <div class="flex-grow">
                    <h3 class="text-sm font-bold text-teal-700 uppercase tracking-wide">Desconexión de Ropa</h3>
                    <p class="text-slate-700 text-sm font-semibold leading-snug">
                        Ve al baño, quítate la ropa y ponla en el cesto de la ropa sucia.
                    </p>
                </div>
                <div class="px-2 text-right text-xs text-teal-500 font-bold hidden md:block">
                    ¡Orden total! 🧺
                </div>
            </div>

            <!-- PASO 3 -->
            <div id="step-3" class="step-card flex items-center bg-white border-2 border-cyan-200 rounded-2xl p-3 shadow-md border-l-8 border-l-cyan-400 hover:border-cyan-400">
                <div class="flex-shrink-0 w-12 h-12 bg-cyan-500 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md border-2 border-white">
                    3
                </div>
                <!-- Mini Avatar SVG de Robot Duchándose con Agua y Espuma -->
                <div class="w-16 h-16 mx-3 flex items-center justify-center bg-cyan-100 rounded-xl border border-cyan-200 relative overflow-hidden">
                    <svg class="w-12 h-12 animate-pulse" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="18" y="20" width="28" height="24" rx="4" fill="#06B6D4" stroke="#0891B2" stroke-width="2"/>
                        <circle cx="27" cy="29" r="3" fill="#FFF"/>
                        <circle cx="37" cy="29" r="3" fill="#FFF"/>
                        <!-- Ducha y gotas -->
                        <path d="M12 12 Q32 8 32 16" stroke="#0891B2" stroke-width="2" fill="none"/>
                        <line x1="32" y1="16" x2="32" y2="20" stroke="#06B6D4" stroke-width="1.5" stroke-dasharray="2 2"/>
                        <!-- Burbujas de jabón -->
                        <circle cx="22" cy="42" r="3" fill="#E0F7FA"/>
                        <circle cx="42" cy="42" r="3.5" fill="#E0F7FA"/>
                        <circle cx="32" cy="46" r="2.5" fill="#E0F7FA"/>
                    </svg>
                </div>
                <div class="flex-grow">
                    <h3 class="text-sm font-bold text-cyan-700 uppercase tracking-wide">¡Modo Lavado Activado!</h3>
                    <p class="text-slate-700 text-sm font-bold leading-snug">
                        Entra en la ducha, moja, frota y enjuaga todo tu cuerpo.
                    </p>
                </div>
                <div class="px-2 text-right text-xs text-cyan-500 font-bold hidden md:block">
                    ¡A frotar! 🧼
                </div>
            </div>

            <!-- PASO 4 -->
            <div id="step-4" class="step-card flex items-center bg-white border-2 border-orange-200 rounded-2xl p-3 shadow-sm hover:border-orange-400">
                <div class="flex-shrink-0 w-12 h-12 bg-orange-500 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md border-2 border-white">
                    4
                </div>
                <!-- Mini Avatar SVG de Robot Secándose con Enfoque en Zonas -->
                <div class="w-16 h-16 mx-3 flex items-center justify-center bg-orange-100 rounded-xl border border-orange-200">
                    <svg class="w-12 h-12" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="18" y="16" width="28" height="24" rx="4" fill="#F97316" stroke="#C2410C" stroke-width="2"/>
                        <circle cx="27" cy="25" r="3" fill="white"/>
                        <circle cx="37" cy="25" r="3" fill="white"/>
                        <!-- Toalla envolviendo -->
                        <path d="M14 35 C14 35 28 42 50 35 L48 48 H16 Z" fill="#FED7AA" stroke="#C2410C" stroke-width="1.5"/>
                    </svg>
                </div>
                <div class="flex-grow">
                    <h3 class="text-sm font-bold text-orange-700 uppercase tracking-wide">Secado de Circuitos</h3>
                    <p class="text-slate-700 text-sm font-semibold leading-snug">
                        Seca bien todo tu cuerpo, en especial <span class="underline decoration-wavy decoration-orange-400 font-bold">cabeza, orejas, culo y pies</span>.
                    </p>
                </div>
                <div class="px-2 text-right text-xs text-orange-500 font-bold hidden md:block">
                    ¡Cero humedad! 💨
                </div>
            </div>

            <!-- PASO 5 -->
            <div id="step-5" class="step-card flex items-center bg-white border-2 border-indigo-200 rounded-2xl p-3 shadow-sm hover:border-indigo-400">
                <div class="flex-shrink-0 w-12 h-12 bg-indigo-500 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md border-2 border-white">
                    5
                </div>
                <!-- Mini Avatar SVG de Robot Guapo y Peinado -->
                <div class="w-16 h-16 mx-3 flex items-center justify-center bg-indigo-100 rounded-xl border border-indigo-200">
                    <svg class="w-12 h-12" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Cuerpo y Cabeza -->
                        <rect x="18" y="20" width="28" height="24" rx="4" fill="#6366F1" stroke="#4338CA" stroke-width="2"/>
                        <!-- Antena o Peinado Gracioso con Engranajes -->
                        <path d="M32 10 V20" stroke="#4338CA" stroke-width="2"/>
                        <path d="M28 10 H36" stroke="#4338CA" stroke-width="2"/>
                        <circle cx="27" cy="29" r="3" fill="white"/>
                        <circle cx="37" cy="29" r="3" fill="white"/>
                        <!-- Sonrisa -->
                        <path d="M28 36 Q32 40 36 36" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        <!-- Peine en mano -->
                        <rect x="44" y="16" width="6" height="12" rx="1" fill="#818CF8" stroke="#4338CA" stroke-width="1"/>
                        <line x1="44" y1="19" x2="48" y2="19" stroke="#4338CA" stroke-width="1"/>
                        <line x1="44" y1="22" x2="48" y2="22" stroke="#4338CA" stroke-width="1"/>
                        <line x1="44" y1="25" x2="48" y2="25" stroke="#4338CA" stroke-width="1"/>
                    </svg>
                </div>
                <div class="flex-grow">
                    <h3 class="text-sm font-bold text-indigo-700 uppercase tracking-wide">Puesta a Punto Estelar</h3>
                    <p class="text-slate-700 text-sm font-semibold leading-snug">
                        Ponte la ropa limpia y péinate para lucir genial.
                    </p>
                </div>
                <div class="px-2 text-right text-xs text-indigo-500 font-bold hidden md:block">
                    ¡Guapísimo! ✨
                </div>
            </div>

        </div>

        <!-- MENSAJE DE REFUERZO POSITIVO EN LA PARTE INFERIOR -->
        <div class="flex items-center justify-around bg-gradient-to-r from-emerald-100 to-cyan-100 border-t-4 border-emerald-400 p-3 rounded-2xl mx-2 z-10">
            <div class="text-center">
                <p class="text-xs text-slate-500 uppercase tracking-widest font-bold">Estado del Robot</p>
                <p class="text-emerald-600 font-extrabold text-base">🔋 Batería cargada al 100%</p>
            </div>
            <div class="h-8 w-1 bg-emerald-300 rounded"></div>
            <div class="text-center">
                <p class="text-xs text-slate-500 uppercase tracking-widest font-bold">Próxima Parada</p>
                <p class="text-blue-600 font-extrabold text-base">😴 ¡Dulces sueños de acero!</p>
            </div>
        </div>

        <!-- MARCA INFANTIL DE CONTROL (¡Para pintar o marcar con una pegatina!) -->
        <div class="flex justify-between items-center text-[10px] text-slate-400 px-4 mt-1 border-t border-slate-100 pt-2">
            <span>Diseñado especialmente para el Piloto más limpio del Universo 🚀</span>
            <span class="font-bold text-cyan-500 uppercase">★ Sistema Operativo: ¡Ducha Completada! ★</span>
        </div>

    </div>

    <!-- Modal de Felicitación Custom (Reemplazo amigable de la ventana de alerta) -->
    <div id="modal-felicitacion" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm flex items-center justify-center z-50 hidden no-print">
        <div class="bg-white border-4 border-emerald-400 p-6 rounded-3xl max-w-sm text-center shadow-2xl m-4 transform scale-95 transition-transform duration-300" id="modal-content">
            <div class="text-6xl mb-4 animate-bounce">🤖✨</div>
            <h3 class="title-font text-2xl font-extrabold text-slate-800 mb-2">¡Misión Cumplida!</h3>
            <p class="text-slate-600 font-semibold mb-6">Todos los sistemas están impecables. ¡Has completado tu rutina como un súper robot de primera clase! Ahora, a descansar y recargar baterías. 💤</p>
            <button onclick="cerrarModal()" class="px-6 py-2 bg-emerald-500 text-white font-bold rounded-full shadow-md hover:bg-emerald-600 transition-all">
                ¡Entendido, Capitán! 🚀
            </button>
        </div>
    </div>

    <!-- SCRIPT INTERACTIVO PARA MOTIVACIÓN EXTRA -->
    <script>
        // Función para reproducir un simpático sonido robótico ascendente
        function playSuccessSound() {
            try {
                if (window.Tone) {
                    // Arrancamos el contexto de audio de Tone en el primer clic
                    if (Tone.context.state !== 'running') {
                        Tone.start();
                    }
                    const synth = new Tone.Synth({
                        oscillator: { type: "sine" },
                        envelope: { attack: 0.01, decay: 0.08, sustain: 0.1, release: 0.1 }
                    }).toDestination();
                    
                    const now = Tone.now();
                    // Melodía rápida de éxito de 3 notas
                    synth.triggerAttackRelease("C5", "16n", now);
                    synth.triggerAttackRelease("E5", "16n", now + 0.07);
                    synth.triggerAttackRelease("G5", "8n", now + 0.14);
                } else {
                    // Fallback nativo con la Web Audio API tradicional si falla la CDN
                    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                    const now = audioCtx.currentTime;
                    const playTone = (freq, duration, delay) => {
                        const osc = audioCtx.createOscillator();
                        const gain = audioCtx.createGain();
                        osc.type = 'sine';
                        osc.frequency.setValueAtTime(freq, now + delay);
                        gain.gain.setValueAtTime(0.08, now + delay);
                        gain.gain.exponentialRampToValueAtTime(0.001, now + delay + duration);
                        osc.connect(gain);
                        gain.connect(audioCtx.destination);
                        osc.start(now + delay);
                        osc.stop(now + delay + duration);
                    };
                    playTone(523.25, 0.08, 0);      // C5
                    playTone(659.25, 0.08, 0.07);   // E5
                    playTone(783.99, 0.15, 0.14);   // G5
                }
            } catch (e) {
                console.log("Audio deshabilitado o bloqueado por interacción del navegador", e);
            }
        }

        // Función interactiva para marcar pasos completados en caso de usar en tablet/móvil
        document.querySelectorAll('.step-card').forEach(card => {
            card.addEventListener('click', () => {
                card.classList.toggle('bg-emerald-50');
                card.classList.toggle('border-emerald-500');
                card.classList.toggle('scale-[1.02]');
                
                // Efecto de sonido visual o check
                let badge = card.querySelector('div:first-child');
                if (card.classList.contains('border-emerald-500')) {
                    badge.innerHTML = '<i class="fa-solid fa-check"></i>';
                    badge.classList.remove('bg-blue-500', 'bg-teal-500', 'bg-cyan-500', 'bg-orange-500', 'bg-indigo-500');
                    badge.classList.add('bg-emerald-500');
                    
                    // ¡Reproducir sonido de éxito!
                    playSuccessSound();
                } else {
                    // Restaurar número original según el ID del paso
                    let stepNum = card.id.split('-')[1];
                    badge.innerText = stepNum;
                    badge.classList.remove('bg-emerald-500');
                    // Restaurar color original según el paso
                    const colors = {
                        '1': 'bg-blue-500',
                        '2': 'bg-teal-500',
                        '3': 'bg-cyan-500',
                        '4': 'bg-orange-500',
                        '5': 'bg-indigo-500'
                    };
                    badge.classList.add(colors[stepNum]);
                }
            });
        });

        function completarMision() {
            // Activa un modo de felicitaciones interactivo animado para cuando lo usen en pantalla
            document.querySelectorAll('.step-card').forEach(card => {
                if (!card.classList.contains('border-emerald-500')) {
                    card.classList.add('bg-emerald-50', 'border-emerald-500');
                    let badge = card.querySelector('div:first-child');
                    badge.innerHTML = '<i class="fa-solid fa-check"></i>';
                    badge.classList.remove('bg-blue-500', 'bg-teal-500', 'bg-cyan-500', 'bg-orange-500', 'bg-indigo-500');
                    badge.classList.add('bg-emerald-500');
                }
            });
            
            // Sonar melodía triunfal
            playSuccessSound();
            
            // Mostrar ventana modal interactiva sin bloquear el navegador
            document.getElementById('modal-felicitacion').classList.remove('hidden');
        }

        function cerrarModal() {
            document.getElementById('modal-felicitacion').classList.add('hidden');
        }
    </script>
</body>
</html>
